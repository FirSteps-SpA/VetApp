# Supabase — copia este archivo a .env.local y completa los valores del proyecto.
# Project Settings → API en el dashboard de Supabase.

# URL del proyecto (https://xxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Clave pública anónima (anon/public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clave de servicio (service_role) — SOLO para scripts/seed server-side.
# Nunca exponer en el cliente ni commitear el valor real.
SUPABASE_SERVICE_ROLE_KEY=
