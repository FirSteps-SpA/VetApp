# Supabase — copia este archivo a .env.local y completa los valores del proyecto.
# Project Settings → API en el dashboard de Supabase.

# URL del proyecto (https://xxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Clave pública anónima (anon/public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clave de servicio (service_role) — SOLO server-side (invitaciones, envíos, cron).
# Nunca exponer en el cliente ni commitear el valor real.
SUPABASE_SERVICE_ROLE_KEY=

# URL pública del sitio (para enlaces en emails/notificaciones). Ej: https://vetapp.tudominio.cl
NEXT_PUBLIC_SITE_URL=

# --- Email transaccional (Resend) ---
# https://resend.com → API Keys. Requiere dominio verificado para el "from".
RESEND_API_KEY=
RESEND_FROM="VetApp <noreply@tudominio.cl>"

# --- Web Push (VAPID) ---
# Genera el par con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contacto del emisor (mailto: o URL del sitio)
VAPID_SUBJECT=mailto:contacto@tudominio.cl

# --- Cron de recordatorios ---
# Secreto para proteger /api/cron/notificaciones (Authorization: Bearer <valor>)
CRON_SECRET=
